rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['company_admin', 'super_admin'];
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    // True when the only change is bidsCount incrementing by exactly 1.
    function bidIncrementOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['bidsCount'])
        && request.resource.data.bidsCount == resource.data.bidsCount + 1;
    }

    // -------- USERS --------
    match /users/{uid} {
      // Public profiles readable by anyone; private profiles only by admins.
      allow read: if resource.data.isPrivate != true || isAdmin();
      allow create: if isOwner(uid);
      // Only the user can edit their own doc, except admins can edit any.
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // -------- TASKS --------
    match /tasks/{taskId} {
      // Public (approved) tasks readable by all; owner can always read their own;
      // private tasks readable by admins and the owner.
      allow read: if resource.data.visibility == 'public'
                    ? (resource.data.status != 'pending' || isOwner(resource.data.posterId))
                    : (isAdmin() || isOwner(resource.data.posterId));
      // Creator must be the signed-in user.
      allow create: if isSignedIn() && request.resource.data.posterId == request.auth.uid;
      // Poster, admin, or the assigned tasker can update (status/progress).
      // Any signed-in user may increment bidsCount when placing a bid.
      allow update: if isOwner(resource.data.posterId)
                      || isAdmin()
                      || (isSignedIn() && resource.data.assignedTo == request.auth.uid)
                      || (isSignedIn() && bidIncrementOnly());
      allow delete: if isOwner(resource.data.posterId) || isAdmin();
    }

    // -------- BIDS --------
    match /bids/{bidId} {
      // Bids readable by task owner, the bidder, or admins.
      allow read: if isAdmin()
                    || isOwner(resource.data.bidderId)
                    || (isSignedIn()
                        && exists(/databases/$(database)/documents/tasks/$(resource.data.taskId))
                        && get(/databases/$(database)/documents/tasks/$(resource.data.taskId)).data.posterId == request.auth.uid);
      // Bidder must be the signed-in user; private tasks only bid by admins.
      allow create: if isSignedIn()
                      && request.resource.data.bidderId == request.auth.uid
                      && ( !exists(/databases/$(database)/documents/tasks/$(request.resource.data.taskId))
                          || get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId)).data.visibility == 'public'
                          || isAdmin() );
      // Poster or admin can update a bid (e.g. mark selected).
      allow update: if isAdmin()
                      || (isSignedIn()
                          && exists(/databases/$(database)/documents/tasks/$(resource.data.taskId))
                          && get(/databases/$(database)/documents/tasks/$(resource.data.taskId)).data.posterId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // -------- REVIEWS --------
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.fromId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // -------- CONVERSATIONS --------
    match /conversations/{convId} {
      function participant() {
        return isSignedIn() && request.auth.uid in resource.data.participants;
      }
      allow read: if participant();
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      allow update: if participant();
      allow delete: if isAdmin();
      match /messages/{msgId} {
        allow read: if participant();
        allow create: if participant() && request.resource.data.fromId == request.auth.uid;
        allow update, delete: if isAdmin();
      }
    }

    // -------- NOTIFICATIONS --------
    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}
