rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['company_admin', 'super_admin'])
        || exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        || request.auth.token.email == 'contact.hamzutrader@gmail.com'
      );
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function canManageAdmins() {
      return isSignedIn() && (
        request.auth.token.email == 'contact.hamzutrader@gmail.com'
        || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin'
        )
        || (
          exists(/databases/$(database)/documents/admins/$(request.auth.uid))
          && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.permissions.hasAny(['manageAdmins'])
        )
      );
    }

    function bidIncrementOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['bidsCount'])
        && request.resource.data.bidsCount == resource.data.bidsCount + 1;
    }

    function assignedTaskerProgressOnly() {
      return isSignedIn()
        && resource.data.assignedTo == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'paymentRequested'])
        && (
          request.resource.data.status in ['in_progress', 'completed']
          || (resource.data.status == 'completed' && request.resource.data.paymentRequested == true)
        );
    }

    // Public profiles are discoverable. Internal provider profiles stay hidden.
    match /users/{uid} {
      allow read: if resource.data.isPrivate != true || isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // Approved public tasks are browseable. Pending and private work is limited
    // to the poster, assigned managed provider, and admins.
    match /tasks/{taskId} {
      allow read: if (
        (resource.data.visibility == 'public' && resource.data.status != 'pending')
        || (isSignedIn() && (
          isOwner(resource.data.posterId)
          || resource.data.assignedTo == request.auth.uid
          || isAdmin()
        ))
      );
      allow create: if isSignedIn() && request.resource.data.posterId == request.auth.uid;
      allow update: if isOwner(resource.data.posterId)
                      || isAdmin()
                      || assignedTaskerProgressOnly()
                      || (isSignedIn() && bidIncrementOnly());
      allow delete: if isOwner(resource.data.posterId) || isAdmin();
    }

    match /bids/{bidId} {
      allow read: if isSignedIn() && (
        resource.data.bidderId == request.auth.uid
        || isAdmin()
        || (
          exists(/databases/$(database)/documents/tasks/$(resource.data.taskId))
          && get(/databases/$(database)/documents/tasks/$(resource.data.taskId)).data.posterId == request.auth.uid
        )
      );
      allow create: if isSignedIn()
                      && (request.resource.data.bidderId == request.auth.uid || isAdmin());
      allow update: if isAdmin()
                      || isOwner(resource.data.bidderId)
                      || (
                        isSignedIn()
                        && exists(/databases/$(database)/documents/tasks/$(resource.data.taskId))
                        && get(/databases/$(database)/documents/tasks/$(resource.data.taskId)).data.posterId == request.auth.uid
                      );
      allow delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.fromId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /conversations/{convId} {
      function participant() {
        return isSignedIn() && resource != null && resource.data != null
          && request.auth.uid in resource.data.participants;
      }
      allow read: if participant();
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      allow update: if participant();
      allow delete: if isAdmin();

      match /messages/{msgId} {
        function conversationParticipant() {
          return isSignedIn()
            && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        }
        allow read: if conversationParticipant();
        allow create: if conversationParticipant() && request.resource.data.fromId == request.auth.uid;
        allow update, delete: if isAdmin();
      }
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /wallet_txs/{txId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && (
        isAdmin()
        request.resource.data.userId == request.auth.uid
        || (
          request.resource.data.type == 'release'
          && exists(/databases/$(database)/documents/tasks/$(request.resource.data.taskId))
          && get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId)).data.posterId == request.auth.uid
          && get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId)).data.assignedTo == request.resource.data.userId
        )
      );
      allow update, delete: if isAdmin();
    }

    match /admins/{uid} {
      allow read: if isAdmin();
      allow create, update, delete: if canManageAdmins();
    }

    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
